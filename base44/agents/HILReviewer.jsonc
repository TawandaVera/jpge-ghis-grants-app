      "allowed_operations": [
        "read"
      ]
    },
    {
      "entity_name": "Grant",
      "allowed_operations": [
        "read"
      ]
    },
    {
      "entity_name": "ResearchRun",
      "allowed_operations": [
        "read"
      ]
    }
  ]
}